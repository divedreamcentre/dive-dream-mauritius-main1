# Strapi CMS base URL. Point this at your Strapi instance —
# local dev, staging, or production — no code changes needed.
VITE_STRAPI_URL=http://localhost:1337

# Supabase project — powers the reservation form submission (Reservations.tsx).
# Get these from Settings -> API in the Supabase dashboard. The anon/public
# key is safe to expose client-side; it's gated by Row Level Security.
# Without these set, the booking form shows "Booking system is not
# configured yet" instead of submitting.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
